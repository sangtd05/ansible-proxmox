network:
  version: 2
  renderer: networkd
  ethernets:
    {{ primary_interface }}:
      dhcp4: false
      addresses:
        - {{ current_ip }}/{{ cidr_prefix }}
      routes:
        - to: default
          via: {{ gateway }}
      nameservers:
        addresses:
{% for dns in dns_servers %}
          - {{ dns }}
{% endfor %}
